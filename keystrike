# ─── Block Parser ───────────────────────────────────────────
run_logic_block() {
    local lines=("$@")
    local i=0

    while [ $i -lt ${#lines[@]} ]; do
        line=$(echo "${lines[$i]}" | sed 's/^[ \t]*//;s/[ \t]*$//')
        [[ -z "$line" || "$line" == 'REM '* ]] && ((i++)) && continue

        # --- FUNCTION DEFINITION ---
        if [[ "$line" =~ ^FUNC[[:space:]]+([a-zA-Z0-9_]+)\(\)$ ]]; then
            local func_name="${BASH_REMATCH[1]}"
            local block_lines=""
            ((i++))

            while [ $i -lt ${#lines[@]} ]; do
                local inner_line=$(echo "${lines[$i]}" | sed 's/^[ \t]*//;s/[ \t]*$//')
                [[ "$inner_line" == "END" ]] && break

                block_lines+="${lines[$i]}"$'\n'
                ((i++))
            done

            FUNCTIONS["$func_name"]="$block_lines"
            ((i++))
            continue

        # --- FUNCTION CALL ---
        elif [[ "$line" =~ ^([a-zA-Z0-9_]+)\(\)$ ]]; then
            local func_name="${BASH_REMATCH[1]}"
            if [[ -n "${FUNCTIONS[$func_name]}" ]]; then
                IFS=$'\n' read -rd '' -a FUNC_BODY <<< "${FUNCTIONS[$func_name]}"
                run_logic_block "${FUNC_BODY[@]}"
            else
                log_err "Undefined function: $func_name"
            fi
            ((i++))
            continue

        # --- IF / ELSIF / ELSE Logic ---
        elif [[ "$line" == IF* ]]; then
            local condition="${line#IF }"
            local found_end=false
            local block_lines=()
            local current_depth=1
            local start_idx=$i
            ((i++))
            while [ $i -lt ${#lines[@]} ]; do
                local raw_line="${lines[$i]}"
                local inner_line=$(echo "$raw_line" | sed 's/^[ \t]*//;s/[ \t]*$//')

                [[ "$inner_line" == IF* || "$inner_line" == WHILE* || "$inner_line" == FOR* ]] && ((current_depth++))
                [[ "$inner_line" == "END" ]] && ((current_depth--))

                if [[ $current_depth -eq 0 ]]; then
                    found_end=true
                    break
                fi
                block_lines+=("$raw_line")
                ((i++))
            done

            if eval "[[ $condition ]]"; then
                run_logic_block "${block_lines[@]}"
            fi
            ((i++))
            continue

        # --- WHILE Loop ---
        elif [[ "$line" == WHILE* ]]; then
            local condition="${line#WHILE }"
            local block_lines=()
            ((i++))
            while [ $i -lt ${#lines[@]} ]; do
                local inner_line=$(echo "${lines[$i]}" | sed 's/^[ \t]*//;s/[ \t]*$//')
                [[ "$inner_line" == "END" ]] && break

                block_lines+=("${lines[$i]}")
                ((i++))
            done

            while eval "[[ $condition ]]"; do
                run_logic_block "${block_lines[@]}"
                for var in "${!VARS[@]}"; do
                    condition="${condition//"$var"/"${VARS[$var]}"}"
                done
            done
            ((i++))
            continue

        # --- FOR Loop ---
        elif [[ "$line" == FOR* ]]; then
            local var_name=$(echo "$line" | awk '{print $2}')
            local range=$(echo "$line" | awk '{print $4}' | sed 's/\.\./ /')
            local block_lines=()
            ((i++))
            while [ $i -lt ${#lines[@]} ]; do
                local inner_line=$(echo "${lines[$i]}" | sed 's/^[ \t]*//;s/[ \t]*$//')
                [[ "$inner_line" == "END" ]] && break

                block_lines+=("${lines[$i]}")
                ((i++))
            done

            for val in $(seq $range); do
                VARS["$var_name"]=$val
                run_logic_block "${block_lines[@]}"
            done
            ((i++))
            continue
        fi

        process_cmd "$line"
        ((i++))
    done
}

# ─── Payload ────────────────────────────────────────────────
run_payload() {
    log_info "Running payload ($LOOP times)..."

    mapfile -t PAYLOAD_ARRAY < "$PAYLOAD_FILE"

    for ((n=1; n<=LOOP; n++)); do
        log_info "Loop $n/$LOOP"
        run_logic_block "${PAYLOAD_ARRAY[@]}"
    done

    log_ok "Payload complete"
}


# ─── Interactive ────────────────────────────────────────────
interactive() {
    log_info "Interactive mode started."
    INTERACTIVE_MODE=true
    touch "$HISTFILE"
    history -c
    history -r
    while true; do
        read -e -p "$PS" CMD || break

        [[ -n "$CMD" ]] && history -s "$CMD"
        if [[ "$CMD" == "EXIT" || "$CMD" == "E" ]]; then
            if kill -0 "$ESP_CONN_PID" 2>/dev/null; then
                send "RELEASE ALL"
                sleep 3
            fi
            break
        fi

        process_cmd "$CMD"
    done
}

# ─── Args ───────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -l|--loop)
                if [[ -z "$2" || "$2" =~ ^- ]]; then
                    log_err "--loop requires a numeric argument"
                    trap - EXIT
                    exit 1
                fi

                if ! [[ "$2" =~ ^[0-9]+$ ]]; then
                    log_err "--loop must be a number"
                    trap - EXIT
                    exit 1
                fi
                LOOP="$2"
                shift 2
                ;;

           update)
               curl -sL "https://raw.githubusercontent.com/zacode123/KeyStrike/main/install.sh" | bash
               trap - EXIT
               exit 0
               ;;

           uninstall)
                USR="${PREFIX:-/usr}"
                echo "[*] Uninstalling KeyStrike..."
                rm -f "$USR/bin/keystrike" "$USR/share/keystrike"
                echo "[✓] KeyStrike removed"
                trap - EXIT
                exit 0
                ;;

            -v|--version)
                echo ""
                echo -e "\e[1;36mKeyStrike $VERSION\e[0m" | lolcat
                echo -e "\e[1;33mBLE HID Keyboard Emulation Tool\e[0m"
                echo ""
                trap - EXIT
                exit 0
                ;;

            -h|--help)
                echo ""
                echo -e "\e[1;36mKeyStrike $VERSION\e[0m" | lolcat
                echo ""
                echo -e "              \e[1;33mBLE HID Keyboard Emulation Tool\e[0m"
                echo -e "\e[1;36m=========================[ HELP ]=========================\e[0m" | lolcat
                echo ""
                echo -e " \e[1;33mUSAGE:\e[0m"
                echo -e "   \e[1;32mkeystrike\e[0m"
                echo -e "     → Start interactive mode"
                echo ""
                echo -e "   \e[1;32mkeystrike payload.ks\e[0m"
                echo -e "     → Execute payload file"
                echo ""
                echo -e "   \e[1;32mkeystrike payload.ks --loop 5\e[0m"
                echo -e "     → Run payload 5 times in loop"
                echo ""
                echo -e " \e[1;33mOPTIONS:\e[0m"
                echo -e "   \e[1;32m-h, --help\e[0m        Show this help"
                echo -e "   \e[1;32m-v, --version\e[0m     Show version info"
                echo -e "   \e[1;32m-l, --loop <n>\e[0m    Execute payload n times (default: 1)"
                echo -e "   \e[1;32mupdate\e[0m            Update KeyStrike to the latest version"
                echo -e "   \e[1;32muninstall\e[0m         Uninstall KeyStrike from system"
                echo ""
                echo -e " \e[1;33mPAYLOAD:\e[0m"
                echo -e "   Provide a \e[1;36m.ks\e[0m(KeyStrike Script File) payload file to run"
                echo ""
                echo -e "\e[1;36m==========================================================\e[0m" | lolcat
                echo ""
                trap - EXIT
                exit 0
                ;;

            *.ks)
                if [[ -d "$1" ]]; then
                    log_err "Cannot use payload: $1 is a directory"
                    trap - EXIT
                    exit 1
                fi

                if [[ ! -e "$1" ]]; then
                    log_err "File not found: $1"
                    trap - EXIT
                    exit 1
                fi
                PAYLOAD_FILE="$1"
                shift
                ;;

            *)
                if [[ -d "$1" ]]; then
                    log_err "Cannot use payload: $1 is a directory"
                elif [[ -f "$1" ]]; then
                    log_err "Invalid payload file (must be a KeyStrike Script .ks): $1"
                else
                    log_err "Unknown argument: $1"
                    echo -e "\e[1;36m[?]\e[0m Use: \e[1;32mkeystrike -h / --help\e[0m for usage"
                fi
                trap - EXIT
                exit 1
                ;;
        esac
    done
}

# ─── MAIN ───────────────────────────────────────────────────
parse_args "$@"

if [[ "$LOOP" -gt 1 && -z "$PAYLOAD_FILE" ]]; then
    log_err "-l/--loop requires a .txt payload file"
    trap - EXIT
    exit 1
fi

if !(command -v jq nmap nc ifconfig lolcat figlet >/dev/null); then
    log_info "Updating package list..."

    if command -v sudo >/dev/null 2>&1; then
        sudo apt update
    else
        apt update
    fi
fi

setup_deps
sleep 1
banner
sleep 1
load_keys_json
load_ip

if [[ -z "$ESP_IP" ]]; then
    scan_network
else
    log_info "Using saved IP: $ESP_IP"
fi

log_info "Connecting to $ESP_IP..."

if connect; then
    log_ok "Successfully connected to ESP32"
    read_esp &
    READER_PID=$!
else
    if [[ -n "$ESP_IP" ]]; then
        log_warn "Saved IP failed"
        scan_network
        log_info "Connecting to $ESP_IP..."
        connect
        if connect; then
            log_ok "Successfully connected to ESP32"
            read_esp &
            READER_PID=$!
        else
            log_err "ESP32 network is not reachable"
            exit 1
        fi
    else
        log_warn "Connection failed. Reconnecting..."
        reconnect
    fi
fi

if [[ -n "$PAYLOAD_FILE" ]]; then
    run_payload
    exit 0
else
    PS=$'\n\e[1;32m╔═══\e[1;36m⟦KeyStrike-'"$VERSION"$'@'"$ESP_IP"$'\e[1;32m⟧═══╗\n\e[1;33m└────╼ \e[1;36m❯❯❯\e[0m '
    interactive
    exit 0
fi
