ESP_IP=""
PORT=80
declare -A VARS
declare -A FUNCTIONS
VARS["\$_VERSION"]="$VERSION"
VARS["\$_INIT_TIME"]="$(date +%H:%M:%S)"
VARS["\$_IP"]="$ESP_IP"
VARS["\$_PORT"]="$PORT"
LOOP=1
PAYLOAD_FILE=""
PS=""
INTERACTIVE_MODE=false
ESP_FILE="$HOME/.keystrike_esp"
HISTFILE="$HOME/.keystrike_history"
HISTSIZE=2000
HISTFILESIZE=4000
shopt -s histappend
PROMPT_COMMAND="history -a; history -n"

