    bind '"\e[A": history-search-backward'
    bind '"\e[B": history-search-forward'
fi

trap cleanup EXIT

# ─── Cleanup ────────────────────────────────────────────────
cleanup() {
    local exit_code=$?
    echo -e "\n\e[1;31m[!] Exiting KeyStrike...\e[0m"

    [[ -n "$READER_PID" ]] && kill "$READER_PID" 2>/dev/null
    [[ -n "$ESP_CONN_PID" ]] && kill "$ESP_CONN_PID" 2>/dev/null

    exec 3<&- 2>/dev/null
    exec 4>&- 2>/dev/null

    unset VARS
    unset FUNCTIONS

    jobs -p | xargs -r kill 2>/dev/null

    tput cnorm 2>/dev/null
    exit "$exit_code"
}

# ─── Colors & Logs ──────────────────────────────────────────
grad() {
    local t="$1"
    shift
    local c=("$@")
    local len=${#t}
    local n=${#c[@]}
    local chunk=$(( (len + n - 1) / n ))
    local i=0
    for color in "${c[@]}"; do
        printf "\e[38;5;%sm%s\e[0m" "$color" "${t:i:chunk}"
        i=$((i + chunk))
    done
    echo
}

log_info() {
    local msg
    printf -v msg "%b" "$1"
    printf "\e[38;5;51m[*]\e[0m "
    grad "$msg" 45 39 33 31
}

log_ok() {
    local msg
    printf -v msg "%b" "$1"
    printf "\e[38;5;82m[✓]\e[0m "
    grad "$msg" 120 121 122 123
}

log_warn() {
    local msg
    printf -v msg "%b" "$1"
    printf "\e[38;5;226m[!]\e[0m "
    grad "$msg" 220 216 208 214
}

log_err() {
    local msg
    printf -v msg "%b" "$1"
    printf "\e[38;5;196m[-]\e[0m "
    grad "$msg" 196 202 208 214
}

# ─── Dependency Install ─────────────────────────────────────
install_pkg() {
    PKG=$1
    if command -v sudo >/dev/null 2>&1; then
        sudo apt install -y "$PKG"
    elif command -v apt >/dev/null 2>&1; then
        apt install -y "$PKG"
    else
        log_err "Install $PKG manually"
        exit 1
    fi
}

check_dep() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log_warn "Missing: $1 → Installing..."
        install_pkg "$2"
    else
        log_ok "Found: $1"
    fi
}

setup_deps() {
    log_info "Checking dependencies..."

    [ -f /usr/games/lolcat ] && [ ! -f /usr/bin/lolcat ] && sudo ln -s /usr/games/lolcat /usr/bin/lolcat

    check_dep jq jq
    check_dep nmap nmap
    check_dep nc netcat
    check_dep ifconfig net-tools
    check_dep lolcat lolcat
    check_dep figlet figlet
    log_ok "All dependencies ready"
}

# ─── Banner ─────────────────────────────────────────────────
banner() {
    clear

    TERM_WIDTH=$(tput cols)

    BORDER="═══════════════════════════════════════════════════════════════════════"
    PADDING=$(( (TERM_WIDTH - ${#BORDER}) / 2 ))

    printf "%*s\e[1;36m╔%s╗\e[0m\n" "$PADDING" "" "$BORDER"

    figlet "KeyStrike" | while IFS= read -r line; do
        padding=$(( (TERM_WIDTH - ${#line}) / 2 ))
        printf "%*s%s\n" "$padding" "" "$line"
    done | lolcat

    VER="⟦ $VERSION ⟧"
    padding=$(( (TERM_WIDTH - ${#VER}) / 2 ))
    printf "%*s\e[1;35m%s\e[0m\n" "$padding" "" "$VER"

    SUB="BLE HID Keyboard Emulation Tool"
    padding=$(( (TERM_WIDTH - ${#SUB}) / 2 ))
    printf "%*s\e[1;33m%s\e[0m\n" "$padding" "" "$SUB"

    printf "%*s\e[1;36m╚%s╝\e[0m\n" "$PADDING" "" "$BORDER"

    echo ""
}

# ─── Load Keys ──────────────────────────────────────────────
load_keys_json() {
    USR="${PREFIX:-/usr}"
    FILE="$USR/share/keystrike/key_library.json"
    [[ -f "$FILE" ]] || { log_err "key_library.json not found"; exit 1; }
    KEYS_JSON=$(<"$FILE")
    log_ok "Key library loaded successfully"
}

# ─── Save / Load ESP32 IP ─────────────────────────────────────
save_ip() {
    echo "$ESP_IP" > "$ESP_FILE"
}

load_ip() {
    [[ -f "$ESP_FILE" ]] && ESP_IP=$(cat "$ESP_FILE")
}

# ─── Network Scan ───────────────────────────────────────────
get_ip() {
    ifconfig 2>/dev/null | awk '/wlan/ || /ap/ {iface=1} iface && /inet / {print $2; exit}'
}

getNetwork() {
    local ip=$1

    [[ -z "$ip" ]] && {
        log_err "IP missing"
        exit 1
    }

    local mask cidr

    mask=$(ifconfig 2>/dev/null | awk '/wlan|ap/ {iface=1} iface && /netmask/ {print $4; exit}')

    [[ -z "$mask" ]] && {
        log_err "Failed to get netmask"
        exit 1
    }

    cidr=$(awk -v mask="$mask" '
        BEGIN {
            split(mask, m, ".")
            cidr=0

            for(i in m) {
                if(m[i]==255) cidr+=8
                else if(m[i]==254) cidr+=7
                else if(m[i]==252) cidr+=6
                else if(m[i]==248) cidr+=5
                else if(m[i]==240) cidr+=4
                else if(m[i]==224) cidr+=3
                else if(m[i]==192) cidr+=2
                else if(m[i]==128) cidr+=1
            }

            printf "%d", cidr
        }
    ')

    IFS=. read -r a b c d <<< "$ip"

    case "$cidr" in
      24) echo "$a.$b.$c.0/$cidr" ;;
      16) echo "$a.$b.0.0/$cidr" ;;
      8)  echo "$a.0.0.0/$cidr" ;;
      *)  echo "$a.$b.$c.0/$cidr" ;;
    esac
}

scan_network() {
    WLAN_IP=$(get_ip)
    [[ -z "$WLAN_IP" ]] && { log_err "No WLAN IP found"; exit 1; }

    local spin='-\|/'
    local i=0
    local nmap_output=""

    tput civis
    exec 3< <(nmap -p 80 --open --unprivileged "$(getNetwork "$WLAN_IP")" 2>/dev/null)

    while true; do
        if IFS= read -u 3 -r -t 0.1 line; then
            nmap_output+="$line"$'\n'
        else
            [[ $? -le 128 ]] && break
        fi

        i=$(( (i+1) % 4 ))
        printf "\r\e[K\e[1;36m[%c]\e[0m \e[38;5;51mScanning for ESP32 network...\e[0m" "${spin:$i:1}"
    done

    exec 3<&-
    tput cnorm
    printf "\r\e[K"

    IPS=$(echo "$nmap_output" | grep "Nmap scan report" | awk '{print $5}')

    for ip in $IPS; do
        if [[ "$ip" != "$MY_IP" ]]; then
            ESP_IP="$ip"
            log_ok "ESP32 found: $ESP_IP"
            save_ip
            return 0
        fi
    done

    log_err "No ESP32 found"
    exit 1
}

# ─── Connection ─────────────────────────────────────────────
connect() {
    if ! nc -z -w 3 "$ESP_IP" "$PORT"; then
        return 1
    fi

    coproc ESP_CONN { nc "$ESP_IP" "$PORT" 2>/dev/null; }

    exec 3<&"${ESP_CONN[0]}"
    exec 4>&"${ESP_CONN[1]}"
    return 0
}

reconnect() {
    kill "$ESP_CONN_PID" 2>/dev/null
    kill "$READER_PID" 2>/dev/null

    sleep 1

    if ! connect; then
        log_warn "Reconnect failed. Retrying..."

        kill "$ESP_CONN_PID" 2>/dev/null
        kill "$READER_PID" 2>/dev/null

        sleep 1

        if ! connect; then
            log_warn "Reconnect failed again. Rescanning..."
            clear_ip
            scan_network
            if connect; then
                log_ok "Successfully connected to ESP32"
                read_esp &
                READER_PID=$!
            else
                log_err "ESP32 network is not reachable"
                exit 1
            fi
        fi
    fi

    history -a
    history -c
    history -r
}

# ─── ESP Reader ─────────────────────────────────────────────
read_esp() {
    trap 'echo; return' SIGINT

    while true; do
        IFS= read -r -t 0.5 line <&3 || continue
        echo "$line"
    done
}

# ─── Send ───────────────────────────────────────────────────
check_nc() {
    kill -0 "$ESP_CONN_PID" 2>/dev/null
}

send() {
    local msg="$1"
    printf "%s\n" "$msg" >&4 2>/dev/null;
    sleep 1
    if ! check_nc; then
        log_warn "Connection lost! Reconnecting..."
        reconnect
        sleep 0.2
        printf "%s\n" "$msg" >&4 2>/dev/null;
        sleep 1
        if ! check_nc; then
            exit 1
        fi
    fi
}

# ─── Key Helpers ────────────────────────────────────────────
get_key_hex() {
    echo "$KEYS_JSON" | jq -r --arg k "$1" '.[$k].hex // empty'
}

get_key_info() {
    echo "$KEYS_JSON" | jq -r --arg k "$1" '.[$k].info // empty'
}

get_usage_page() {
    local key="$1"
    local type
    type=$(echo "$KEYS_JSON" | jq -r --arg k "$key" '.[$k].type // empty')
    case "$type" in
        media_key|app)
            echo "0x0C"
            ;;
        *)
            echo "0x07"
            ;;
    esac
}

# ─── Command Processor ──────────────────────────────────────
process_cmd() {
    CMD="$1"

    # ─── VARIABLE RESOLUTION ─────────────────────────
    if ! [[ "$CMD" =~ ^\$[a-zA-Z0-9_]+[[:space:]]*= ]]; then
        if [[ "$CMD" =~ (\$[_a-zA-Z0-9]+) ]]; then
            log_err "Variable is not defined: ${BASH_REMATCH[1]}"
            return
        fi
    fi

    # ─── LOGGING COMMANDS ─────────────────────────
    if [[ "$CMD" =~ ^LOG_(INFO|OK|ERR)[[:space:]]+(.*)$ ]]; then
        TYPE="${BASH_REMATCH[1]}"
        MSG="${BASH_REMATCH[2]}"

        for q in \" \'; do
            [[ "$MSG" == "$q"* ]] && MSG="${MSG#$q}"
            [[ "$MSG" == *"$q" ]] && MSG="${MSG%$q}"
        done

        case "$TYPE" in
            INFO) log_info "$MSG" ;;
            OK)   log_ok   "$MSG" ;;
            ERR)  log_err  "$MSG" ;;
        esac
        return
    fi

        if [[ "$CMD" =~ ^(\$[a-zA-Z0-9_]+)[[:space:]]*=[[:space:]]*(.*)$ ]]; then
        VAR_NAME="${BASH_REMATCH[1]}"
        RIGHT_SIDE="${BASH_REMATCH[2]}"

        case "$VAR_NAME" in
            "\$_VERSION"|"\$_INIT_TIME"|"\$_TIME"|"\$_IP"|"\$_PORT")
                log_err "Access Denied: Cannot modify read-only system variable $VAR_NAME"
                return ;;
        esac

        if [[ "$RIGHT_SIDE" == EXEC\ * ]]; then
            LOCAL_CMD="${RIGHT_SIDE#EXEC }"
            
            if [[ -z "$(echo "$LOCAL_CMD" | xargs)" ]]; then
                log_err "Syntax Error: EXEC command is missing for $VAR_NAME!"
                return
            fi

            OUT_TMP=$(mktemp)
            ERR_TMP=$(mktemp)

            eval "$LOCAL_CMD" >"$OUT_TMP" 2>"$ERR_TMP"
            VARS["\$EXIT_CODE"]=$?

            VARS["$VAR_NAME"]=$(<"$OUT_TMP")
            VARS["${VAR_NAME}_ERR"]=$(<"$ERR_TMP")

            rm -f "$OUT_TMP" "$ERR_TMP"
            return

        elif [[ "$RIGHT_SIDE" =~ ^\[(.*)\]$ ]]; then
            KEYSTRIKE_CMD="${BASH_REMATCH[1]}"
            
            if [[ -z "$(echo "$KEYSTRIKE_CMD" | xargs)" ]]; then
                log_err "Syntax Error: Command inside brackets [] is empty!"
                return
            fi

            OUT_TMP=$(mktemp)
            ERR_TMP=$(mktemp)

            process_cmd "$KEYSTRIKE_CMD" >"$OUT_TMP" 2>"$ERR_TMP"
            IFS= read -r -t 2 RESPONSE <&3

            [[ -n "$RESPONSE" ]] && echo "$RESPONSE" >> "$OUT_TMP"

            VARS["$VAR_NAME"]=$(sed -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$OUT_TMP")
            VARS["${VAR_NAME}_ERR"]=$(sed -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$ERR_TMP")

            rm -f "$OUT_TMP" "$ERR_TMP"
            return

        else
            VAR_VAL="$RIGHT_SIDE"

            if [[ -z "$VAR_VAL" ]]; then
                log_err "Syntax Error: Missing value for $VAR_NAME! Use \"\" for empty assignment."
                return
            fi

            for q in \" \'; do
                [[ "$VAR_VAL" == "$q"* ]] && VAR_VAL="${VAR_VAL#$q}"
                [[ "$VAR_VAL" == *"$q" ]] && VAR_VAL="${VAR_VAL%$q}"
            done

            VARS["$VAR_NAME"]="$VAR_VAL"
            return
        fi
    fi

    if [[ "$CMD" == EXEC\ * ]]; then
        LOCAL_CMD="${CMD#EXEC }"

        if [[ -z "$(echo "$LOCAL_CMD" | xargs)" ]]; then
            log_err "Syntax Error: EXEC command is empty!"
            return
        fi

        eval "$LOCAL_CMD"
        VARS["\$EXIT_CODE"]=$?
        return
    fi

    if [[ "$CMD" == EXEC\ * ]]; then
        LOCAL_CMD="${CMD#EXEC }"

        eval "$LOCAL_CMD"
        VARS["\$EXIT_CODE"]=$?
        return
    fi

    [[ -z "$CMD" || "$CMD" == 'REM '* ]] && return
    [[ "$CMD" == *"\$_TIME"* ]] && CMD="${CMD//"$_TIME"/"$(date +%H:%M:%S)"}" && return

    # ─── CLEAR SCREEN ─────────────────────────────
    [[ "$CMD" == "CLEAR" || "$CMD" == "CLS" ]] && clear && return

    # ─── BLE / WIFI ──────────────────────────────
    [[ "$CMD" == BLE* ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == WIFI* ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return

    # ─── STRING / STRINGLN ──────────────────────────
    if [[ "$CMD" == STRING* ]]; then
        local IS_LN=false
        [[ "$CMD" == STRINGLN* ]] && IS_LN=true

        if $IS_LN; then
            TEXT="${CMD#STRINGLN}"
        else
            TEXT="${CMD#STRING}"
        fi

        TEXT="${TEXT# }"

        for q in \" \'; do
            [[ "$TEXT" == "$q"* ]] && TEXT="${TEXT#$q}"
            [[ "$TEXT" == *"$q" ]] && TEXT="${TEXT%$q}"
        done

        send "TYPE $TEXT"

        if $IS_LN; then
            send "PRESS 0x07 0x28"
        fi
        return
    fi

    # ─── SYSTEM ─────────────────────────────────
    [[ "$CMD" == "SYSINFO" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == "RESET" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == "RESTART" || "$CMD" == "RST" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return

    # ─── EXEC WITH DYNAMIC CAPTURE ────────────────
    if [[ "$CMD" =~ ^(\$[a-zA-Z0-9_]+)[[:space:]]*=[[:space:]]*EXEC[[:space:]]+(.*)$ ]]; then
        TARGET_VAR="${BASH_REMATCH[1]}"
        LOCAL_CMD="${BASH_REMATCH[2]}"

        LOG_VAR="${TARGET_VAR}_LOG"
        ERR_VAR="${TARGET_VAR}_ERR"

        for var in "${!VARS[@]}"; do
            LOCAL_CMD="${LOCAL_CMD//"$var"/"${VARS[$var]}"}"
        done

        log_info "Executing CMD: $LOCAL_CMD"

        OUT_TMP=$(mktemp)
        ERR_TMP=$(mktemp)

        eval "$LOCAL_CMD" >"$OUT_TMP" 2>"$ERR_TMP"
        VARS["\$EXIT_CODE"]=$?

        if [[ -n "$TARGET_VAR" ]]; then
            VARS["$LOG_VAR"]=$(cat "$OUT_TEMP")
            VARS["$ERR_VAR"]=$(cat "$ERR_TEMP")
            VARS["$TARGET_VAR"]="${VARS["$LOG_VAR"]}"
        fi

        rm -f "$OUT_TMP" "$ERR_TMP"
        return
    elif [[ "$CMD" =~ ^EXEC[[:space:]]+(.*)$ ]]; then
        LOCAL_CMD="${BASH_REMATCH[1]}"

        for var in "${!VARS[@]}"; do
            LOCAL_CMD="${LOCAL_CMD//"$var"/"${VARS[$var]}"}"
        done

        log_info "Executing local: $LOCAL_CMD"
        eval "$LOCAL_CMD"
        VARS["\$EXIT_CODE"]=$?
        return
    fi

    # ─── SET VARIABLE ────────────────────────────
    if [[ "$CMD" == SET* ]]; then
        VAR_NAME=$(echo "$CMD" | awk '{print $2}')

        case "$VAR_NAME" in
            "\$_VERSION"|"\$_OS"|"\$_TIME"|"\$_IP"|"\$_PORT")
                log_warn "Access Denied: $VAR_NAME is a read-only system constant."
                return
                ;;
        esac

        VAR_VAL="${CMD#*= }"
        for q in \" \'; do
            VAR_VAL="${VAR_VAL#$q}"
            VAR_VAL="${VAR_VAL%$q}"
        done

        VARS["$VAR_NAME"]="$VAR_VAL"
        return
    fi

    # ─── DELAY ─────────────────────────────────
    if [[ "$CMD" == DELAY* ]]; then
        SEC=$(echo "$CMD" | awk '{print $2}')
        echo ""
        log_info "Waiting for $SEC sec"
        sleep "$SEC"
        return
    fi

    # ─── RELEASE ────────────────────────────────
    if [[ "$CMD" == RELEASE* ]]; then
        ARG=$(echo "$CMD" | awk '{print $2}')

        if [[ -z "$ARG" ]]; then
            echo ""
            log_warn "Usage: RELEASE <KEY|HEX>"
            return
        fi

        if [[ "$ARG" == "ALL" ]]; then
            echo "[>] RELEASE ALL" | lolcat
            send "RELEASE ALL"
            return
        fi

        if [[ "$ARG" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo ""
            log_warn "Direct HEX not allowed. Use KEY name only."
            return
        fi

        HEX=$(get_key_hex "$ARG")
        if [[ -z "$HEX" ]]; then
            echo ""
            log_warn "Unknown key: $ARG"
            return
        fi

        USAGE_PAGE=$(get_usage_page "$ARG")
        if [[ -z "$USAGE_PAGE" ]]; then
            echo ""
            log_warn "Unknown usage page for: $ARG"
            return
        fi

        printf "[>] RELEASE %s (%s %s)\n" "$ARG" "$USAGE_PAGE" "$HEX" | lolcat
        send "RELEASE $USAGE_PAGE $HEX"
        return
    fi

    # ─── PRESS / TAP ────────────────────────────
    if [[ "$CMD" == PRESS* || "$CMD" == TAP* ]]; then
        ACTION=$(echo "$CMD" | awk '{print $1}')
        ARG1=$(echo "$CMD" | awk '{print $2}')
        ARG2=$(echo "$CMD" | awk '{print $3}')

        if [[ -z "$ARG1" ]]; then
            echo ""
            log_warn "Usage: $ACTION [MODIFIER] <KEY>"
            return
        fi

        if [[ "$ARG1" =~ ^0x[0-9A-Fa-f]+$ || "$ARG2" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo ""
            log_warn "Direct HEX input not allowed. Use KEY names only."
            return
        fi

        MOD_HEX=""
        KEY_NAME=""

        if [[ -n "$ARG2" ]]; then
            MOD_HEX=$(get_key_hex "$ARG1")
            KEY_NAME="$ARG2"
            if [[ -z "$MOD_HEX" ]]; then
                echo ""
                log_warn "Unknown modifier: $ARG1"
                return
            fi
        else
            KEY_NAME="$ARG1"
        fi

        KEY_HEX=$(get_key_hex "$KEY_NAME")
        if [[ -z "$KEY_HEX" ]]; then
            echo ""
            log_warn "Unknown key: $KEY_NAME"
            return
        fi

        USAGE_PAGE=$(get_usage_page "$KEY_NAME")
        if [[ -z "$USAGE_PAGE" ]]; then
            echo ""
            log_warn "Usage page not found for: $KEY_NAME"
            return
        fi

        if [[ -n "$MOD_HEX" ]]; then
            printf "[>] %s %s %s MOD:%s\n" "$ACTION" "$USAGE_PAGE" "$KEY_HEX" "$MOD_HEX" | lolcat
            send "$ACTION $USAGE_PAGE $KEY_HEX $MOD_HEX"
        else
            printf "[>] %s %s %s\n" "$ACTION" "$USAGE_PAGE" "$KEY_HEX" | lolcat
            send "$ACTION $USAGE_PAGE $KEY_HEX"
        fi
        return
    fi

    # ─── KEYS ───────────────────────────────────
    if [[ "$CMD" == KEYS* || "$CMD" == K* ]]; then

        ARG1=$(echo "$CMD" | awk '{print $2}')
        ARG2=$(echo "$CMD" | awk '{print $3}')

        if [[ "${ARG1^^}" =~ ^(GLOBAL|DESKTOP)$ ]]; then
            PLAT_VAL="${ARG1^^}"
            SUBCMD="${ARG2^^}"
        else
            PLAT_VAL="${ARG2^^}"
            SUBCMD="${ARG1^^}"
        fi

        PLATFORM_FILTER=""
        if [[ "$PLAT_VAL" == "DESKTOP" ]]; then
            PLATFORM_FILTER=' and .value.platform == "desktop"'
        elif [[ "$PLAT_VAL" == "GLOBAL" ]]; then
            PLATFORM_FILTER=' and .value.platform == "global"'
        fi

        case "${SUBCMD^^}" in
            HELP|\?)
                printf '\n\033[1;35mKeyStrike %s - BLE HID Key Library \033[0m\n\n' "$VERSION"
                printf '\033[1;36mUsage:\033[0m\n'
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show library info (overview + notes)\033[0m\n' "INFO"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show help menu (all commands + usage)\033[0m\n' "HELP / ?"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show ALL keys (no filtering)\033[0m\n' "KEYS ALL"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show only Desktop supported keys\033[0m\n' "KEYS DESKTOP"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show Global keys (works on both Android and Desktop)\033[0m\n' "KEYS GLOBAL"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Alphabet keys (A-Z) global (both Android and Desktop supported)\033[0m\n' "KEYS LETTERS / LTR"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Number keys (0-9) global (both Android and Desktop supported)\033[0m\n' "KEYS NUMBERS / NUM"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Special characters (! @ # $ etc)\033[0m\n' "KEYS SYMBOLS / SYM [DESKTOP|GLOBAL]"
