VERSION="v4.2"
ESP_IP=""
PORT=80
LOOP=1
PAYLOAD_FILE=""
ESP_FILE="$HOME/.keystrike_esp"
HISTFILE="$HOME/.keystrike_history"
HISTSIZE=2000
HISTFILESIZE=4000
shopt -s histappend
PROMPT_COMMAND="history -a; history -n"

if [[ $- == *i* ]]; then
    bind '"\e[A": history-search-backward'
    bind '"\e[B": history-search-forward'
fi

trap cleanup EXIT

# ─── Cleanup ────────────────────────────────────────────────
cleanup() {
    echo -e "\n\e[1;31m[!] Exiting KeyStrike...\e[0m"

    [[ -n "$READER_PID" ]] && kill "$READER_PID" 2>/dev/null
    [[ -n "$ESP_CONN_PID" ]] && kill "$ESP_CONN_PID" 2>/dev/null

    exec 3<&- 2>/dev/null
    exec 4>&- 2>/dev/null

    jobs -p | xargs -r kill 2>/dev/null

    tput cnorm 2>/dev/null
    exit 0
}

# ─── Colors & Logs ──────────────────────────────────────────
grad() {
    local t="$1"
    shift
    local c=("$@")
    local len=${#t}
    local n=${#c[@]}
    local chunk=$(( (len + n - 1) / n ))
    local i=0
    for color in "${c[@]}"; do
        printf "\e[38;5;%sm%s\e[0m" "$color" "${t:i:chunk}"
        i=$((i + chunk))
    done
    echo
}

log_info()  { printf "\e[38;5;51m[*]\e[0m ";  grad "$1" 45 39 33 31;     }
log_ok()    { printf "\e[38;5;82m[✓]\e[0m ";  grad "$1" 120 121 122 123; }
log_warn()  { printf "\e[38;5;226m[!]\e[0m "; grad "$1" 220 216 208 214; }
log_err()   { printf "\e[38;5;196m[-]\e[0m "; grad "$1" 196 202 208 214; }

# ─── Dependency Install ─────────────────────────────────────
install_pkg() {
    PKG=$1
    if command -v sudo >/dev/null 2>&1; then
        sudo apt install -y "$PKG"
    elif command -v apt >/dev/null 2>&1; then
        apt install -y "$PKG"
    else
        log_err "Install $PKG manually"
        exit 1
    fi
}

check_dep() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log_warn "Missing: $1 → Installing..."
        install_pkg "$2"
    else
        log_ok "Found: $1"
    fi
}

setup_deps() {
    log_info "Checking dependencies..."

    [ -f /usr/games/lolcat ] && [ ! -f /usr/bin/lolcat ] && sudo ln -s /usr/games/lolcat /usr/bin/lolcat

    check_dep jq jq
    check_dep nmap nmap
    check_dep nc netcat
    check_dep ifconfig net-tools
    check_dep lolcat lolcat
    check_dep figlet figlet
    log_ok "All dependencies ready"
}

# ─── Banner ─────────────────────────────────────────────────
banner() {
    clear

    TERM_WIDTH=$(tput cols)

    BORDER="═══════════════════════════════════════════════════════════════════════"
    PADDING=$(( (TERM_WIDTH - ${#BORDER}) / 2 ))

    printf "%*s\e[1;36m╔%s╗\e[0m\n" "$PADDING" "" "$BORDER"

    figlet "KeyStrike" | while IFS= read -r line; do
        padding=$(( (TERM_WIDTH - ${#line}) / 2 ))
        printf "%*s%s\n" "$padding" "" "$line"
    done | lolcat

    VER="⟦ $VERSION ⟧"
    padding=$(( (TERM_WIDTH - ${#VER}) / 2 ))
    printf "%*s\e[1;35m%s\e[0m\n" "$padding" "" "$VER"

    SUB="BLE HID Keyboard Emulation Tool"
    padding=$(( (TERM_WIDTH - ${#SUB}) / 2 ))
    printf "%*s\e[1;33m%s\e[0m\n" "$padding" "" "$SUB"

    printf "%*s\e[1;36m╚%s╝\e[0m\n" "$PADDING" "" "$BORDER"

    echo ""
}

# ─── Load Keys ──────────────────────────────────────────────
load_keys_json() {
    USR="${PREFIX:-/usr}"
    FILE="$USR/share/keystrike/key_library.json"
    [[ -f "$FILE" ]] || { log_err "key_library.json not found"; exit 1; }
    KEYS_JSON=$(<"$FILE")
    log_ok "Key library loaded successfully"
}

# ─── Save / Load ESP IP ─────────────────────────────────────
save_ip() {
    echo "$ESP_IP" > "$ESP_FILE"
}

clear_ip() {
    > "$ESP_FILE"
}

load_ip() {
    [[ -f "$ESP_FILE" ]] && ESP_IP=$(cat "$ESP_FILE")
}

# ─── Network Scan ───────────────────────────────────────────
get_ip() {
    ifconfig 2>/dev/null | awk '/wlan/ || /ap/ {iface=1} iface && /inet / {print $2; exit}'
}

getNetwork() {
    local ip=$1

    [[ -z "$ip" ]] && {
        log_err "IP missing"
        exit 1
    }

    local mask cidr

    mask=$(ifconfig 2>/dev/null | awk '/wlan|ap/ {iface=1} iface && /netmask/ {print $4; exit}')

    [[ -z "$mask" ]] && {
        log_err "Failed to get netmask"
        exit 1
    }

    cidr=$(awk -v mask="$mask" '
        BEGIN {
            split(mask, m, ".")
            cidr=0

            for(i in m) {
                if(m[i]==255) cidr+=8
                else if(m[i]==254) cidr+=7
                else if(m[i]==252) cidr+=6
                else if(m[i]==248) cidr+=5
                else if(m[i]==240) cidr+=4
                else if(m[i]==224) cidr+=3
                else if(m[i]==192) cidr+=2
                else if(m[i]==128) cidr+=1
            }

            printf "%d", cidr
        }
    ')

    IFS=. read -r a b c d <<< "$ip"

    case "$cidr" in
      24) echo "$a.$b.$c.0/$cidr" ;;
      16) echo "$a.$b.0.0/$cidr" ;;
      8)  echo "$a.0.0.0/$cidr" ;;
      *)  echo "$a.$b.$c.0/$cidr" ;;
    esac
}

scan_network() {
    WLAN_IP=$(get_ip)
    [[ -z "$WLAN_IP" ]] && { log_err "No WLAN IP found"; exit 1; }

    local spin='-\|/'
    local i=0
    local nmap_output=""

    tput civis
    exec 3< <(nmap -p 80 --open --unprivileged "$(getNetwork "$WLAN_IP")" 2>/dev/null)

    while true; do
        if IFS= read -u 3 -r -t 0.1 line; then
            nmap_output+="$line"$'\n'
        else
            [[ $? -le 128 ]] && break
        fi

        i=$(( (i+1) % 4 ))
        printf "\r\e[K\e[1;36m[%c]\e[0m \e[38;5;51mScanning for ESP32 network...\e[0m" "${spin:$i:1}"
    done

    exec 3<&-
    tput cnorm
    printf "\r\e[K"

    IPS=$(echo "$nmap_output" | grep "Nmap scan report" | awk '{print $5}')

    for ip in $IPS; do
        if [[ "$ip" != "$MY_IP" ]]; then
            ESP_IP="$ip"
            log_ok "ESP32 found: $ESP_IP"
            save_ip
            return 0
        fi
    done

    log_warn "No ESP32 found"
    exit 1
}

# ─── Connection ─────────────────────────────────────────────
connect() {
    coproc ESP_CONN { nc "$ESP_IP" "$PORT" 2>/dev/null; }

    exec 3<&"${ESP_CONN[0]}"
    exec 4>&"${ESP_CONN[1]}"
}

check_nc() {
    kill -0 "$ESP_CONN_PID" 2>/dev/null
}

reconnect() {
    kill "$ESP_CONN_PID" 2>/dev/null
    kill "$READER_PID" 2>/dev/null

    sleep 1
    connect

    if ! check_nc; then
        log_warn "Reconnect failed. Retrying..."

        kill "$ESP_CONN_PID" 2>/dev/null
        kill "$READER_PID" 2>/dev/null

        sleep 1
        connect

        if ! check_nc; then
            log_warn "Reconnect failed again. Rescanning..."

            clear_ip
            scan_network
            connect
        fi
    fi

    log_ok "Successfully connected to ESP32"
    read_esp &
    READER_PID=$!

    history -a
    history -c
    history -r
}

# ─── ESP Reader ─────────────────────────────────────────────
read_esp() {
    trap 'echo; return' SIGINT

    first=1

    while true; do
        IFS= read -r -t 0.5 line <&3 || continue

        if (( first )); then
            printf '\n'
            first=0
        fi

        if [[ "$line" == /p/p* ]]; then
            print_prompt
            first=1
        else
            echo "$line"
        fi
    done
}

# ─── Send ───────────────────────────────────────────────────
send() {
    local msg="$1"
    printf "%s\n" "$msg" >&4 2>/dev/null;
    sleep 1
    if ! check_nc; then
        log_warn "Connection lost! Reconnecting..."
        reconnect
        sleep 0.2
        printf "%s\n" "$msg" >&4 2>/dev/null;
        sleep 1
        if ! check_nc; then
            exit 1
        fi
    fi
}

# ─── Key Helpers ────────────────────────────────────────────
get_key_hex() {
    echo "$KEYS_JSON" | jq -r --arg k "$1" '.[$k].hex // empty'
}

get_key_info() {
    echo "$KEYS_JSON" | jq -r --arg k "$key" '.[$k].info // empty'
}

# ─── Command Processor ──────────────────────────────────────
process_cmd() {
    CMD="$1"

    [[ -z "$CMD" ]] && print_prompt && return

    # ─── BLE / WIFI ─────────────────────────────
    [[ "$CMD" == BLE* ]]   && echo "[>] $CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == WIFI* ]]  && echo "[>] $CMD" | lolcat && send "$CMD" && return

    # ─── TYPE ───────────────────────────────────
    [[ "$CMD" == TYPE* ]]  && echo "[>] $CMD" | lolcat && send "$CMD" && return

    # ─── SYSTEM ─────────────────────────────────
    [[ "$CMD" == "SYSINFO" ]] && echo "[>] $CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == "RESTART" || "$CMD" == "RST" ]] && echo "[>] $CMD" | lolcat && send "$CMD" && return

    # ─── DELAY ──────────────────────────────────
    if [[ "$CMD" == DELAY* ]]; then
        SEC=$(echo "$CMD" | awk '{print $2}')
        echo ""
        log_info "Waiting $SEC sec"
        sleep "$SEC"
        print_prompt
        return
    fi

    # ─── RELEASE ────────────────────────────────
    if [[ "$CMD" == RELEASE* ]]; then
        ARG=$(echo "$CMD" | awk '{print $2}')

        if [[ -z "$ARG" ]]; then
            echo ""
            log_warn "Usage: $RELEASE <KEY|HEX>"
            print_prompt
            return
        fi

        if [[ "$ARG" == "ALL" ]]; then
            echo "[>] RELEASE ALL" | lolcat
            send "RELEASE ALL"
            return
        fi

        if [[ "$ARG" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo "[>] RELEASE $ARG" | lolcat
            send "RELEASE $ARG"
            return
        fi

        HEX=$(get_key_hex "$ARG")
        if [[ -z "$HEX" ]]; then
            echo ""
            log_warn "Unknown key: $ARG"
            print_prompt
            return
        fi

        echo "[>] RELEASE $ARG ($HEX)" | lolcat
        send "RELEASE $HEX"
        return
    fi

    # ─── PRESS / TAP ────────────────────────────
    if [[ "$CMD" == PRESS* || "$CMD" == TAP* ]]; then
        ACTION=$(echo "$CMD" | awk '{print $1}')
        ARG=$(echo "$CMD" | awk '{print $2}')

        if [[ -z "$ARG" ]]; then
            echo ""
            log_warn "Usage: $ACTION <KEY|HEX>"
            print_prompt
            return
        fi

        if [[ "$ARG" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo "[>] $ACTION $ARG" | lolcat
            send "$ACTION $ARG"
            return
        fi

        HEX=$(get_key_hex "$ARG")
        if [[ -z "$HEX" ]]; then
            echo ""
            log_warn "Unknown key: $ARG"
            print_prompt
            return
        fi

        echo "[>] $ACTION $ARG ($HEX)" | lolcat
        send "$ACTION $HEX"
        return
    fi

    # ─── KEYS ───────────────────────────────────
    if [[ "$CMD" == "KEYS" || "$CMD" == "K" ]]; then
        SUBCMD="${2:-}"

        case "${SUBCMD^^}" in
            HELP|H|\?)
                echo -e "\n${C_BOLD}${C_MAGENTA}KeyStrike $VERSION - BLE HID Key Control${C_RESET}\n"
                echo -e "${C_BOLD}${C_CYAN}Usage:${C_RESET}"
                echo -e "  $0 <command> [options]\n"
                echo -e "${C_BOLD}${C_YELLOW}Commands:${C_RESET}"
                echo -e "  KEYS                      - Show ALL keys"
                echo -e "  KEYS ANDROID / KEYS A     - Show Android-specific keys"
                echo -e "  KEYS DESKTOP / KEYS D     - Show Desktop/Computer keys"
                echo -e "  KEYS GLOBAL / KEYS G      - Show Global keys (all platforms)"
                echo -e "  KEYS SYSTEM / KEYS SYS    - Show System Control keys"
                echo -e "  KEYS APPS                 - Show App Launch keys"
                echo -e "  KEYS LETTERS              - Show Letter keys (A-Z)"
                echo -e "  KEYS NUMBERS / KEYS NUM   - Show Number keys (0-9)"
                echo -e "  KEYS SYMBOLS              - Show Symbol/Special character keys"
                echo -e "  KEYS MEDIA / KEYS MD      - Show Media/Playback keys"
                echo -e "  KEYS MEDIA ANDROID / KEYS MD A - Show Android media keys"
                echo -e "  KEYS MEDIA DESKTOP / KEYS MD D - Show Desktop media keys"
                echo -e "  HELP                      - Show this help message\n"
                echo -e "${C_BOLD}${C_CYAN}Examples:${C_RESET}"
                echo -e "  $0 KEYS ANDROID     - List all Android keys"
                echo -e "  $0 KEYS SYS         - List all system control keys"
                echo -e "  $0 KEYS A           - Shorthand for KEYS ANDROID"
                echo -e "  $0 HELP             - Show help\n"
                print_prompt
                return
                ;;
            ANDROID|A)
                JQ_QUERY='to_entries[] | select(.value.type != null and (.value.type | contains("android"))) | "\(.key)"'
                ;;
            DESKTOP|D)
                JQ_QUERY='to_entries[] | select(.value.type != null and (.value.type | contains("desktop"))) | "\(.key)"'
                ;;
            GLOBAL|G)
                JQ_QUERY='to_entries[] | select(.value.type == "global" or .value.type == "modifier" or .value.type == "number" or .value.type == "letter" or .value.type == "symbol") | "\(.key)"'
                ;;
            SYSTEM|SYS)
                JQ_QUERY='to_entries[] | select(.value.type == "system_control") | "\(.key)"'
                ;;
            APPS)
                JQ_QUERY='to_entries[] | select(.value.type != null and (.value.type | contains("app"))) | "\(.key)"'
                ;;
            LETTERS)
                JQ_QUERY='to_entries[] | select(.value.type == "letter") | "\(.key)"'
                ;;
            NUMBERS|NUM)
                JQ_QUERY='to_entries[] | select(.value.type == "number") | "\(.key)"'
                ;;
            SYMBOLS)
                JQ_QUERY='to_entries[] | select(.value.type == "symbol") | "\(.key)"'
                ;;
            MEDIA|MD)
                FILTER_ARG="${3:-}"
                if [[ "${FILTER_ARG^^}" == "A" || "${FILTER_ARG^^}" == "ANDROID" ]]; then
                    JQ_QUERY='to_entries[] | select(.value.type == "android") | "\(.key)"'
                elif [[ "${FILTER_ARG^^}" == "D" || "${FILTER_ARG^^}" == "DESKTOP" ]]; then
                    JQ_QUERY='to_entries[] | select(.value.type == "desktop") | "\(.key)"'
                else
                    JQ_QUERY='to_entries[] | select(.value.type == "global" or .value.type == "android") | "\(.key)"'
                fi
                ;;
            *)
                JQ_QUERY='to_entries[] | select(.key != "_notes" and .key != "_info") | "\(.key)"'
                ;;
        esac

        echo ""
        printf "                                  \e[1;35mKeyStrike\e[0m \e[1;33m$VERSION\e[0m \e[1;36mKEY library\e[0m\n"
        printf "   \e[1;36mKEY        \e[1;34m<---------------------------------------------------------------->        \e[1;36mINFO\e[0m\n"
        printf "   \e[1;36m------------------------------------------------------------------------------------------\e[0m\n"

        echo "$KEYS_JSON" | jq -r "$JQ_QUERY" | sort | while read -r key; do
            if [[ "${SUBCMD^^}" == "MEDIA" || "${SUBCMD^^}" == "MD" ]]; then
                if ! [[ "$key" =~ ^K_[A-Z_]+$ ]] || [[ "$key" =~ ^A_ ]]; then
                    continue
                fi
            fi

            info=$(get_key_info "$key")
            hex=$(get_key_hex "$key")

            if [[ "${SUBCMD^^}" == "APPS" ]]; then
                app_pkg=$(echo "$KEYS_JSON" | jq -r ".\"$key\".package // .\"$key\".intent // .\"$key\".executable // empty")
                [[ -n "$app_pkg" ]] && info="$info [$app_pkg]"
            elif [[ "${SUBCMD^^}" == "SYSTEM" || "${SUBCMD^^}" == "SYS" ]]; then
                plat=$(echo "$KEYS_JSON" | jq -r ".\"$key\".platform // \"both\"")
                [[ "$plat" == "android" ]] && plat_icon="🤖"
                [[ "$plat" == "both" ]] && plat_icon="🔄"
                [[ "$plat" == "desktop" ]] && plat_icon="🖥️ "
                info="$info [$plat_icon $hex]"
            elif [[ "$hex" != "N/A" && -n "$hex" ]]; then
                info="$info [$hex]"
            fi

            if [ ${#info} -gt 63 ]; then
                info="${info:0:60}..."
            fi

            printf "   \e[1;32m%-24s\e[0m : \e[1;37m%63s\e[0m\n\n" "$key" "$info"
        done | lolcat
        echo ""
        printf "   \e[1;36m------------------------------------------------------------------------------------------\e[0m\n"
        print_prompt
        return
    fi

    # ─── HELP ───────────────────────────────────
    if [[ "$CMD" == "HELP" || "$CMD" == "?" ]]; then
        echo ""
        echo -e "\e[1;36m=========[ KEYSTRIKE HELP $VERSION ]=========\e[0m" | lolcat
        echo ""
        echo -e "\e[1;33mGENERAL:\e[0m"
        echo -e "  \e[1;32mHELP / ?\e[0m              Show this help"
        echo -e "  \e[1;32mRESTART / RST\e[0m         Restart ESP32"
        echo -e "  \e[1;32mSYSINFO\e[0m               Get system info"
        echo -e "  \e[1;32mDELAY <TIME>\e[0m          Pause the script for specified seconds"
        echo -e "  \e[1;32mCLEAR / CLS\e[0m           Clear screen"
        echo -e "  \e[1;32mEXIT / E\e[0m              Exit KeyStrike"
        echo ""
        echo -e "\e[1;33mBLE:\e[0m"
        echo -e "  \e[1;32mBLE INFO\e[0m              Show BLE info"
        echo -e "  \e[1;32mBLE INFO <N> <M>\e[0m      Set name & manufacturer"
        echo -e "  \e[1;32mBLE INIT\e[0m              Start BLE"
        echo -e "  \e[1;32mBLE END / STOP\e[0m        Stop BLE"
        echo -e "  \e[1;32mBLE POWER <1-8> \e[0m      Set BLE TX Power (1=-12dBm … 8=+9dBm)"
        echo -e "  \e[1;32mBLE CLEARBONDS\e[0m        Clear saved BLE bonds"
        echo -e "  \e[1;32mBLE RESET\e[0m             Reset BLE settings"
        echo ""
        echo -e "\e[1;33mWIFI:\e[0m"
        echo -e "  \e[1;32mWIFI INFO\e[0m             Show WiFi config"
        echo -e "  \e[1;32mWIFI INFO <S> <P>\e[0m     Set SSID & Password"
        echo -e "  \e[1;32mWIFI RESET\e[0m            Reset WiFi settings"
        echo ""
        echo -e "\e[1;33mKEYBOARD:\e[0m"
        echo -e "  \e[1;32mPRESS   <KEY|HEX>\e[0m     Press key"
        echo -e "  \e[1;32mTAP     <KEY|HEX>\e[0m     Tap key"
        echo -e "  \e[1;32mRELEASE ALL\e[0m           Release all keys"
        echo -e "  \e[1;32mRELEASE <KEY|HEX>\e[0m     Release specific key"
        echo -e "  \e[1;32mTYPE    <TEXT>\e[0m        Type text"
        echo ""
        echo -e "\e[1;33mKEY LIBRARY:\e[0m"
        echo -e "  \e[0;36mUse 'KEYS / K HELP' to view the key library\e[0m"
        echo -e "\e[1;36m========================================\e[0m" | lolcat
        echo ""
        print_prompt
        return
    fi

    # ─── UNKNOWN ────────────────────────────────
    echo ""
    log_warn "Unknown command: $CMD"
    echo -e "\e[1;36m[?]\e[0m Type \e[1;32mHELP / ?\e[0m to see available commands" | lolcat
    print_prompt
}

# ─── Payload ────────────────────────────────────────────────
run_payload() {
    log_info "Running payload ($LOOP times)..."

    for ((i=1; i<=LOOP; i++)); do
        log_info "Loop $i/$LOOP"

        while IFS= read -r line; do
            process_cmd "$line"
        done < "$PAYLOAD_FILE"

        echo ""
    done

    log_ok "Payload complete"
}

# ─── Interactive ────────────────────────────────────────────
interactive() {
    log_info "Interactive mode started."
    touch "$HISTFILE"
    history -c
    history -r
    print_prompt
    while true; do
        read -e -p " " CMD || break

        [[ -n "$CMD" ]] && history -s "$CMD"
        [[ "$CMD" == "EXIT" || "$CMD" == "E" ]] && break
        [[ "$CMD" == "CLEAR" || "$CMD" == "CLS" ]] && clear && print_prompt && continue

        process_cmd "$CMD"
    done
}

# ─── Print Prompt ───────────────────────────────────────────
print_prompt() {
    PS=$'\n\e[1;32m╔═══\e[1;36m⟦KeyStrike-'"$VERSION"$'@'"$ESP_IP"$'\e[1;32m⟧═══╗\n\e[1;33m└────╼ \e[1;36m❯❯❯\e[0m'
    printf "$PS"
}

# ─── Args ───────────────────────────────────────────────────
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -l|--loop)
                if [[ -z "$2" || "$2" =~ ^- ]]; then
                    log_err "--loop requires a numeric argument"
                    trap - EXIT
                    exit 1
                fi

                if ! [[ "$2" =~ ^[0-9]+$ ]]; then
                    log_err "--loop must be a number"
                    trap - EXIT
                    exit 1
                fi
                LOOP="$2"
                shift 2
                ;;

           update)
               curl -sL "https://raw.githubusercontent.com/zacode123/KeyStrike/main/install.sh" | bash

           uninstall)
                USR="${PREFIX:-/usr}"
                echo "[*] Uninstalling KeyStrike..."
                rm -f "$USR/bin/keystrike" "$USR/share/keystrike"
                echo "[✓] KeyStrike removed"

            -v|--version)
                echo ""
                echo -e "\e[1;36mKeyStrike $VERSION\e[0m" | lolcat
                echo -e "\e[1;33mBLE HID Keyboard Emulation Tool\e[0m"
                echo ""
                trap - EXIT
                exit 0
                ;;

            -h|--help)
                echo ""
                echo -e "\e[1;36mKeyStrike $VERSION\e[0m" | lolcat
                echo ""
                echo -e "              \e[1;33mBLE HID Keyboard Emulation Tool\e[0m"
                echo -e "\e[1;36m=========================[ HELP ]=========================\e[0m" | lolcat
                echo ""
                echo -e " \e[1;33mUSAGE:\e[0m"
                echo -e "   \e[1;32mkeystrike\e[0m"
                echo -e "     → Start interactive mode"
                echo ""
                echo -e "   \e[1;32mkeystrike payload.txt\e[0m"
                echo -e "     → Execute payload file"
                echo ""
                echo -e "   \e[1;32mkeystrike payload.txt --loop 5\e[0m"
                echo -e "     → Run payload 5 times in loop"
                echo ""
                echo -e " \e[1;33mOPTIONS:\e[0m"
                echo -e "   \e[1;32m-h, --help\e[0m        Show this help"
                echo -e "   \e[1;32m-v, --version\e[0m     Show version info"
                echo -e "   \e[1;32m-l, --loop <n>\e[0m    Execute payload n times (default: 1)"
                echo -e "   \e[1;32mupdate\e[0m            Update KeyStrike to the latest version"
                echo -e "   \e[1;32muninstall\e[0m            Uninstall KeyStrike from system"
                echo ""
                echo -e " \e[1;33mPAYLOAD:\e[0m"
                echo -e "   Provide a \e[1;36m.txt\e[0m file with commands to auto-run"
                echo ""
                echo -e "\e[1;36m==========================================================\e[0m" | lolcat
                echo ""
                trap - EXIT
                exit 0
                ;;

            *.txt)
                if [[ -d "$1" ]]; then
                    log_err "Cannot use payload: $1 is a directory"
                    trap - EXIT
                    exit 1
                fi

                if [[ ! -e "$1" ]]; then
                    log_err "File not found: $1"
                    trap - EXIT
                    exit 1
                fi
                PAYLOAD_FILE="$1"
                shift
                ;;

            *)
                if [[ -d "$1" ]]; then
                    log_err "Cannot use payload: $1 is a directory"
                elif [[ -f "$1" ]]; then
                    log_err "Invalid payload file (must be .txt): $1"
                else
                    log_err "Unknown argument: $1"
                    echo -e "\e[1;36m[?]\e[0m Use: \e[1;32mkeystrike -h / --help\e[0m for usage"
                fi
                trap - EXIT
                exit 1
                ;;
        esac
    done
}

# ─── MAIN ───────────────────────────────────────────────────
parse_args "$@"

if [[ "$LOOP" -gt 1 && -z "$PAYLOAD_FILE" ]]; then
    log_err "-l/--loop requires a .txt payload file"
    trap - EXIT
    exit 1
fi

if !(command -v jq nmap nc ifconfig lolcat figlet >/dev/null); then
    log_info "Updating package list..."

    if command -v sudo >/dev/null 2>&1; then
        sudo apt update
    else
        apt update
    fi
fi

setup_deps
sleep 1
banner
sleep 1
load_keys_json
load_ip

if [[ -n "$ESP_IP" ]]; then
    log_info "Using saved IP: $ESP_IP"
    if ! nc -z "$ESP_IP" "$PORT" 2>/dev/null; then
        log_warn "Saved IP failed"
        clear_ip
        scan_network
    fi
else
    scan_network
fi

log_info "Connecting to $ESP_IP..."

connect

if check_nc; then
    log_ok "Successfully connected to ESP32"
    read_esp &
    READER_PID=$!
else
    log_warn "Connection failed! Reconnecting..."
    reconnect
fi

if [[ -n "$PAYLOAD_FILE" ]]; then
    run_payload
    exit 0
else
    interactive
fi
