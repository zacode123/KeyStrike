VERSION="v5.1"
ESP_IP=""
PORT=80
LOOP=1
PAYLOAD_FILE=""
PS=""
INTERACTIVE_MODE=false
ESP_FILE="$HOME/.keystrike_esp"
HISTFILE="$HOME/.keystrike_history"
HISTSIZE=2000
HISTFILESIZE=4000
shopt -s histappend
PROMPT_COMMAND="history -a; history -n"

if [[ $- == *i* ]]; then
    bind '"\e[A": history-search-backward'
    bind '"\e[B": history-search-forward'
fi

trap cleanup EXIT

# ─── Cleanup ────────────────────────────────────────────────
cleanup() {
    echo -e "\n\e[1;31m[!] Exiting KeyStrike...\e[0m"

    [[ -n "$READER_PID" ]] && kill "$READER_PID" 2>/dev/null
    [[ -n "$ESP_CONN_PID" ]] && kill "$ESP_CONN_PID" 2>/dev/null

    exec 3<&- 2>/dev/null
    exec 4>&- 2>/dev/null

    jobs -p | xargs -r kill 2>/dev/null

    tput cnorm 2>/dev/null
    exit 0
}

# ─── Colors & Logs ──────────────────────────────────────────
grad() {
    local t="$1"
    shift
    local c=("$@")
    local len=${#t}
    local n=${#c[@]}
    local chunk=$(( (len + n - 1) / n ))
    local i=0
    for color in "${c[@]}"; do
        printf "\e[38;5;%sm%s\e[0m" "$color" "${t:i:chunk}"
        i=$((i + chunk))
    done
    echo
}

log_info()  { printf "\e[38;5;51m[*]\e[0m ";  grad "$1" 45 39 33 31;     }
log_ok()    { printf "\e[38;5;82m[✓]\e[0m ";  grad "$1" 120 121 122 123; }
log_warn()  { printf "\e[38;5;226m[!]\e[0m "; grad "$1" 220 216 208 214; }
log_err()   { printf "\e[38;5;196m[-]\e[0m "; grad "$1" 196 202 208 214; }

# ─── Dependency Install ─────────────────────────────────────
install_pkg() {
    PKG=$1
    if command -v sudo >/dev/null 2>&1; then
        sudo apt install -y "$PKG"
    elif command -v apt >/dev/null 2>&1; then
        apt install -y "$PKG"
    else
        log_err "Install $PKG manually"
        exit 1
    fi
}

check_dep() {
    if ! command -v "$1" >/dev/null 2>&1; then
        log_warn "Missing: $1 → Installing..."
        install_pkg "$2"
    else
        log_ok "Found: $1"
    fi
}

setup_deps() {
    log_info "Checking dependencies..."

    [ -f /usr/games/lolcat ] && [ ! -f /usr/bin/lolcat ] && sudo ln -s /usr/games/lolcat /usr/bin/lolcat

    check_dep jq jq
    check_dep nmap nmap
    check_dep nc netcat
    check_dep ifconfig net-tools
    check_dep lolcat lolcat
    check_dep figlet figlet
    log_ok "All dependencies ready"
}

# ─── Banner ─────────────────────────────────────────────────
banner() {
    clear

    TERM_WIDTH=$(tput cols)

    BORDER="═══════════════════════════════════════════════════════════════════════"
    PADDING=$(( (TERM_WIDTH - ${#BORDER}) / 2 ))

    printf "%*s\e[1;36m╔%s╗\e[0m\n" "$PADDING" "" "$BORDER"

    figlet "KeyStrike" | while IFS= read -r line; do
        padding=$(( (TERM_WIDTH - ${#line}) / 2 ))
        printf "%*s%s\n" "$padding" "" "$line"
    done | lolcat

    VER="⟦ $VERSION ⟧"
    padding=$(( (TERM_WIDTH - ${#VER}) / 2 ))
    printf "%*s\e[1;35m%s\e[0m\n" "$padding" "" "$VER"

    SUB="BLE HID Keyboard Emulation Tool"
    padding=$(( (TERM_WIDTH - ${#SUB}) / 2 ))
    printf "%*s\e[1;33m%s\e[0m\n" "$padding" "" "$SUB"

    printf "%*s\e[1;36m╚%s╝\e[0m\n" "$PADDING" "" "$BORDER"

    echo ""
}

# ─── Load Keys ──────────────────────────────────────────────
load_keys_json() {
    USR="${PREFIX:-/usr}"
    FILE="$USR/share/keystrike/key_library.json"
    [[ -f "$FILE" ]] || { log_err "key_library.json not found"; exit 1; }
    KEYS_JSON=$(<"$FILE")
    log_ok "Key library loaded successfully"
}

# ─── Save / Load ESP IP ─────────────────────────────────────
save_ip() {
    echo "$ESP_IP" > "$ESP_FILE"
}

clear_ip() {
    > "$ESP_FILE"
}

load_ip() {
    [[ -f "$ESP_FILE" ]] && ESP_IP=$(cat "$ESP_FILE")
}

# ─── Network Scan ───────────────────────────────────────────
get_ip() {
    ifconfig 2>/dev/null | awk '/wlan/ || /ap/ {iface=1} iface && /inet / {print $2; exit}'
}

getNetwork() {
    local ip=$1

    [[ -z "$ip" ]] && {
        log_err "IP missing"
        exit 1
    }

    local mask cidr

    mask=$(ifconfig 2>/dev/null | awk '/wlan|ap/ {iface=1} iface && /netmask/ {print $4; exit}')

    [[ -z "$mask" ]] && {
        log_err "Failed to get netmask"
        exit 1
    }

    cidr=$(awk -v mask="$mask" '
        BEGIN {
            split(mask, m, ".")
            cidr=0

            for(i in m) {
                if(m[i]==255) cidr+=8
                else if(m[i]==254) cidr+=7
                else if(m[i]==252) cidr+=6
                else if(m[i]==248) cidr+=5
                else if(m[i]==240) cidr+=4
                else if(m[i]==224) cidr+=3
                else if(m[i]==192) cidr+=2
                else if(m[i]==128) cidr+=1
            }

            printf "%d", cidr
        }
    ')

    IFS=. read -r a b c d <<< "$ip"

    case "$cidr" in
      24) echo "$a.$b.$c.0/$cidr" ;;
      16) echo "$a.$b.0.0/$cidr" ;;
      8)  echo "$a.0.0.0/$cidr" ;;
      *)  echo "$a.$b.$c.0/$cidr" ;;
    esac
}

scan_network() {
    WLAN_IP=$(get_ip)
    [[ -z "$WLAN_IP" ]] && { log_err "No WLAN IP found"; exit 1; }

    local spin='-\|/'
    local i=0
    local nmap_output=""

    tput civis
    exec 3< <(nmap -p 80 --open --unprivileged "$(getNetwork "$WLAN_IP")" 2>/dev/null)

    while true; do
        if IFS= read -u 3 -r -t 0.1 line; then
            nmap_output+="$line"$'\n'
        else
            [[ $? -le 128 ]] && break
        fi

        i=$(( (i+1) % 4 ))
        printf "\r\e[K\e[1;36m[%c]\e[0m \e[38;5;51mScanning for ESP32 network...\e[0m" "${spin:$i:1}"
    done

    exec 3<&-
    tput cnorm
    printf "\r\e[K"

    IPS=$(echo "$nmap_output" | grep "Nmap scan report" | awk '{print $5}')

    for ip in $IPS; do
        if [[ "$ip" != "$MY_IP" ]]; then
            ESP_IP="$ip"
            log_ok "ESP32 found: $ESP_IP"
            save_ip
            return 0
        fi
    done

    log_warn "No ESP32 found"
    exit 1
}

# ─── Connection ─────────────────────────────────────────────
connect() {
    coproc ESP_CONN { nc "$ESP_IP" "$PORT" 2>/dev/null; }

    exec 3<&"${ESP_CONN[0]}"
    exec 4>&"${ESP_CONN[1]}"
}

check_nc() {
    kill -0 "$ESP_CONN_PID" 2>/dev/null
}

reconnect() {
    kill "$ESP_CONN_PID" 2>/dev/null
    kill "$READER_PID" 2>/dev/null

    sleep 1
    connect

    if ! check_nc; then
        log_warn "Reconnect failed. Retrying..."

        kill "$ESP_CONN_PID" 2>/dev/null
        kill "$READER_PID" 2>/dev/null

        sleep 1
        connect

        if ! check_nc; then
            log_warn "Reconnect failed again. Rescanning..."

            clear_ip
            scan_network
            connect
        fi
    fi

    log_ok "Successfully connected to ESP32"
    read_esp &
    READER_PID=$!

    history -a
    history -c
    history -r
}

# ─── ESP Reader ─────────────────────────────────────────────
read_esp() {
    trap 'echo; return' SIGINT

    while true; do
        IFS= read -r -t 0.5 line <&3 || continue
        echo "$line"
    done
}

# ─── Send ───────────────────────────────────────────────────
send() {
    local msg="$1"
    printf "%s\n" "$msg" >&4 2>/dev/null;
    sleep 1
    if ! check_nc; then
        log_warn "Connection lost! Reconnecting..."
        reconnect
        sleep 0.2
        printf "%s\n" "$msg" >&4 2>/dev/null;
        sleep 1
        if ! check_nc; then
            exit 1
        fi
    fi
}

# ─── Key Helpers ────────────────────────────────────────────
get_key_hex() {
    echo "$KEYS_JSON" | jq -r --arg k "$1" '.[$k].hex // empty'
}

get_key_info() {
    echo "$KEYS_JSON" | jq -r --arg k "$1" '.[$k].info // empty'
}

get_usage_page() {
    local key="$1"
    local type
    type=$(echo "$KEYS_JSON" | jq -r --arg k "$key" '.[$k].type // empty')
    case "$type" in
        media_key|app)
            echo "0x0C"
            ;;
        *)
            echo "0x07"
            ;;
    esac
}

# ─── Command Processor ──────────────────────────────────────
process_cmd() {
    CMD="$1"

    [[ -z "$CMD" || "$CMD" == 'REM '* ]] && return

    # ─── CLEAR SCREEN ─────────────────────────────
    [[ "$CMD" == "CLEAR" || "$CMD" == "CLS" ]] && clear && return

    # ─── BLE / WIFI ──────────────────────────────
    [[ "$CMD" == BLE* ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == WIFI* ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return

    # ─── TYPE ──────────────────────────────────
    [[ "$CMD" == TYPE* ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return

    # ─── SYSTEM ─────────────────────────────────
    [[ "$CMD" == "SYSINFO" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == "RESET" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return
    [[ "$CMD" == "RESTART" || "$CMD" == "RST" ]] && printf "\n[>] %s\n" "$CMD" | lolcat && send "$CMD" && return

    # ─── DELAY ─────────────────────────────────
    if [[ "$CMD" == DELAY* ]]; then
        SEC=$(echo "$CMD" | awk '{print $2}')
        echo ""
        log_info "Waiting $SEC sec"
        sleep "$SEC"
        return
    fi

    # ─── RELEASE ────────────────────────────────
    if [[ "$CMD" == RELEASE* ]]; then
        ARG=$(echo "$CMD" | awk '{print $2}')

        if [[ -z "$ARG" ]]; then
            echo ""
            log_warn "Usage: RELEASE <KEY|HEX>"
            return
        fi

        if [[ "$ARG" == "ALL" ]]; then
            echo "[>] RELEASE ALL" | lolcat
            send "RELEASE ALL"
            return
        fi

        if [[ "$ARG" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo ""
            log_warn "Direct HEX not allowed. Use KEY name only."
            return
        fi

        HEX=$(get_key_hex "$ARG")
        if [[ -z "$HEX" ]]; then
            echo ""
            log_warn "Unknown key: $ARG"
            return
        fi

        USAGE_PAGE=$(get_usage_page "$ARG")
        if [[ -z "$USAGE_PAGE" ]]; then
            echo ""
            log_warn "Unknown usage page for: $ARG"
            return
        fi

        printf "[>] RELEASE %s (%s %s)\n" "$ARG" "$USAGE_PAGE" "$HEX" | lolcat
        send "RELEASE $USAGE_PAGE $HEX"
        return
    fi

    # ─── PRESS / TAP ────────────────────────────
    if [[ "$CMD" == PRESS* || "$CMD" == TAP* ]]; then
        ACTION=$(echo "$CMD" | awk '{print $1}')
        ARG1=$(echo "$CMD" | awk '{print $2}')
        ARG2=$(echo "$CMD" | awk '{print $3}')

        if [[ -z "$ARG1" ]]; then
            echo ""
            log_warn "Usage: $ACTION [MODIFIER] <KEY>"
            return
        fi

        if [[ "$ARG1" =~ ^0x[0-9A-Fa-f]+$ || "$ARG2" =~ ^0x[0-9A-Fa-f]+$ ]]; then
            echo ""
            log_warn "Direct HEX input not allowed. Use KEY names only."
            return
        fi

        MOD_HEX=""
        KEY_NAME=""

        if [[ -n "$ARG2" ]]; then
            MOD_HEX=$(get_key_hex "$ARG1")
            KEY_NAME="$ARG2"
            if [[ -z "$MOD_HEX" ]]; then
                echo ""
                log_warn "Unknown modifier: $ARG1"
                return
            fi
        else
            KEY_NAME="$ARG1"
        fi

        KEY_HEX=$(get_key_hex "$KEY_NAME")
        if [[ -z "$KEY_HEX" ]]; then
            echo ""
            log_warn "Unknown key: $KEY_NAME"
            return
        fi

        USAGE_PAGE=$(get_usage_page "$KEY_NAME")
        if [[ -z "$USAGE_PAGE" ]]; then
            echo ""
            log_warn "Usage page not found for: $KEY_NAME"
            return
        fi

        if [[ -n "$MOD_HEX" ]]; then
            printf "[>] %s %s %s MOD:%s\n" "$ACTION" "$USAGE_PAGE" "$KEY_HEX" "$MOD_HEX" | lolcat
            send "$ACTION $USAGE_PAGE $KEY_HEX $MOD_HEX"
        else
            printf "[>] %s %s %s\n" "$ACTION" "$USAGE_PAGE" "$KEY_HEX" | lolcat
            send "$ACTION $USAGE_PAGE $KEY_HEX"
        fi
        return
    fi

    # ─── KEYS ───────────────────────────────────
    if [[ "$CMD" == KEYS* || "$CMD" == K* ]]; then
        SUBCMD=$(echo "$CMD" | awk '{print $2}')
        FILTER_ARG=$(echo "$CMD" | awk '{print $3}')
        PLATFORM_FILTER=""

        if [[ "${FILTER_ARG^^}" == "D" || "${FILTER_ARG^^}" == "DESKTOP" ]]; then
            PLATFORM_FILTER=' and .value.platform == "desktop"'
        elif [[ "${FILTER_ARG^^}" == "G" || "${FILTER_ARG^^}" == "GLOBAL" ]]; then
            PLATFORM_FILTER=' and .value.platform == "global"'
        fi

        case "${SUBCMD^^}" in
            HELP|H|\?)
                printf '\n\033[1;35mKeyStrike %s - BLE HID Key Library \033[0m\n\n' "$VERSION"
                printf '\033[1;36mUsage:\033[0m\n'
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show library info (overview + notes)\033[0m\n' "INFO"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show help menu (all commands + usage)\033[0m\n' "HELP / H / ?"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show ALL keys (no filtering)\033[0m\n' "KEYS ALL"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show only Desktop supported keys\033[0m\n' "KEYS DESKTOP / D"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show Global keys (works on Android + Desktop)\033[0m\n' "KEYS GLOBAL / G"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Alphabet keys (A-Z)\033[0m\n' "KEYS LETTERS / LTR [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Number keys (0-9)\033[0m\n' "KEYS NUMBERS / NUM [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Special characters (! @ # $ etc)\033[0m\n' "KEYS SYMBOLS / SYM [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Modifier keys (CTRL, ALT, SHIFT, WIN)\033[0m\n' "KEYS MODIFIERS / MOD [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- System control keys (ENTER, ESC, TAB)\033[0m\n' "KEYS CONTROL / CTRL [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Arrow navigation keys (↑ ↓ ← →)\033[0m\n' "KEYS ARROWS / ARR [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Navigation keys (HOME, END, PAGE_UP/PAGE_DOWN)\033[0m\n' "KEYS NAVIGATION / NAV [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Function keys (F1 - F12)\033[0m\n' "KEYS FUNCTION / FN [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Media control keys (Play, Pause, Volume, Next, Prev)\033[0m\n' "KEYS MEDIA / MD [D|G]"
                printf '  \033[1;32m%-30s\033[0m \033[0;37m- Show system app launch keys (Android + Desktop supported)\033[0m\n' "KEYS APPS / APP"
                printf '\n\033[1;33mFilter Guide:\033[0m\n'
                printf '  \033[1;34m%-14s\033[0m \033[0;37m→ Show only Desktop-supported keys\033[0m\n' "D / DESKTOP"
                printf '  \033[1;34m%-14s\033[0m \033[0;37m→ Show cross-platform keys (Android + Desktop)\033[0m\n' "G / GLOBAL"
                printf '  No filter shows all available keys for that type\033[0m\n'
                printf '\n\033[1;33mBehavior Notes:\033[0m\n'
                printf '  \033[0;36m•\033[0m \033[0;37mFilters apply to ALL key categories except APPS\033[0m\n'
                printf '  \033[0;36m•\033[0m \033[0;37mAPPS are always global by design\033[0m\n'
                printf '  \033[0;36m•\033[0m \033[0;37mUnknown commands will show an error message\033[0m\n'
                printf '  \033[0;36m•\033[0m \033[0;37mOutput is sorted and color formatted for readability\033[0m\n'
                printf '\n\033[1;36mExamples:\033[0m\n'
                printf '  \033[1;32m%-28s\033[0m \033[0;37m- Desktop modifier keys only\033[0m\n' "KEYS MOD D"
                printf '  \033[1;32m%-28s\033[0m \033[0;37m- Global function keys\033[0m\n' "KEYS FN G"
                printf '  \033[1;32m%-28s\033[0m \033[0;37m- Desktop media controls\033[0m\n' "KEYS MEDIA D"
                return
                ;;

            DESKTOP|D)
                KEY_TYPE="Desktop"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.platform == "desktop") | .key'
                ;;
            GLOBAL|G)
                KEY_TYPE="Global"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.platform == "global") | .key'
                ;;
            LETTERS|LTR)
                KEY_TYPE="Letter"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "letter")'"$PLATFORM_FILTER"' | .key'
                ;;
            NUMBERS|NUM)
                KEY_TYPE="Number"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "number")'"$PLATFORM_FILTER"' | .key'
                ;;
            SYMBOLS|SYM)
                KEY_TYPE="Symbol"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "symbol")'"$PLATFORM_FILTER"' | .key'
                ;;
            MODIFIERS|MOD)
                KEY_TYPE="Modifier"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "modifier")'"$PLATFORM_FILTER"' | .key'
                ;;
            CONTROL|CTRL)
                KEY_TYPE="Control"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "control_key")'"$PLATFORM_FILTER"' | .key'
                ;;
            ARROWS|ARR)
                KEY_TYPE="Arrow"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "arrow_key")'"$PLATFORM_FILTER"' | .key'
                ;;
            NAVIGATION|NAV)
                KEY_TYPE="Navigation"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "navigation_key")'"$PLATFORM_FILTER"' | .key'
                ;;
            FUNCTION|FN)
                KEY_TYPE="Function"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "function_key")'"$PLATFORM_FILTER"' | .key'
                ;;
            MEDIA|MD)
                KEY_TYPE="Media"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "media_key")'"$PLATFORM_FILTER"' | .key'
                ;;
            APPS|APP)
                KEY_TYPE="App launch"
                JQ_QUERY='to_entries[] | select(.value | type == "object") | select(.value.type == "app") | .key'
                ;;
            ALL)
                KEY_TYPE="All"
                JQ_QUERY='to_entries[] | select(.key != "_notes") | select(.value | type == "object") | .key'
                ;;
            INFO)
                printf "\033[1;36m====================================\033[0m\n"
                printf "\033[1;36m        LIBRARY INFO\033[0m\n"
                printf "\033[1;36m====================================\033[0m\n\n"
                jq -r '.info' "$FILE"
                echo ""
                printf "\033[1;35mNOTES\033[0m\n\n"
                jq -r '._notes | to_entries[] | "\(.key)|\(.value)"' "$FILE" |
                while IFS='|' read -r k v; do
                    printf "\033[1;32m%-18s\033[0m : \033[0;37m%s\033[0m\n" "$k" "$v"
                done
                return
                ;;
            *)
                log_err "Unknown command '${CMD}'"
                log_info "Type: 'KEYS / K HELP' for more info"
                return
            ;;
        esac
        echo ""
        printf "                                  \e[1;35mKeyStrike\e[0m \e[1;33m$VERSION\e[0m \e[1;36mKEY library\e[0m\n"
        printf "                                  \e[1;32m$KEY_TYPE\e[0m \e[1;37mkeys\e[0m\n"
        printf "   \e[1;36mKEY        \e[1;34m<---------------------------------------------------------------->        \e[1;36mINFO\e[0m\n"
        printf "   \e[1;36m------------------------------------------------------------------------------------------\e[0m\n"

        echo "$KEYS_JSON" | jq -r "$JQ_QUERY" | while read -r key; do
            [[ -z "$key" ]] && continue

            info=$(get_key_info "$key")
            hex=$(get_key_hex "$key")

            if [[ -n "$hex" && "$hex" != "N/A" ]]; then
                info="$info [$hex]"
            fi

            if [ ${#info} -gt 63 ]; then
                info="${info:0:60}..."
            fi
            printf "   \e[1;32m%-24s\e[0m : \e[1;37m%63s\e[0m\n\n" "$key" "$info"
        done | lolcat
        echo ""
        printf "   \e[1;36m------------------------------------------------------------------------------------------\e[0m\n"
        return
    fi

    # ─── HELP ───────────────────────────────────
    if [[ "$CMD" == "HELP" || "$CMD" == "?" ]]; then
        echo ""
        echo -e "\e[1;36m===================[ KEYSTRIKE HELP $VERSION ]===================\e[0m" | lolcat
        echo ""
        echo -e "\e[1;33mGENERAL:\e[0m"
